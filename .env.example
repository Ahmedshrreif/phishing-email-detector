APP_ENV=development
APP_NAME=PhishGuard
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DATABASE_URL=postgresql://phishguard:phishguard@db:5432/phishguard

JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

MODEL_STORAGE_PATH=/app/ml/artifacts
ACTIVE_MODEL_VERSION=starter-nlp-v1

MAX_EMAIL_FILE_SIZE_MB=10
STORE_EMAIL_CONTENT=true
DATA_RETENTION_DAYS=90
AUTO_CREATE_TABLES=false
AUTO_SEED_ADMIN=true
ADMIN_EMAIL=admin@phishguard.com
ADMIN_PASSWORD=AdminAccess!234
ADMIN_FULL_NAME=PhishGuard Owner

RATE_LIMIT_ANALYSIS_PER_MINUTE=10
RATE_LIMIT_LOGIN_PER_MINUTE=5

ENABLE_URL_LIVE_PROBE=true
URL_PROBE_TIMEOUT_SECONDS=4
URL_PROBE_MAX_REDIRECTS=5
URL_PROBE_MAX_URLS_PER_ANALYSIS=20

SAFE_BROWSING_API_KEY=
VIRUSTOTAL_API_KEY=

NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
